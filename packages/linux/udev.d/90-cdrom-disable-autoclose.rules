ACTION!="add", GOTO="end"

# This fixes the drive tray retraction bug when the cdrom is present as a module
SUBSYSTEM=="module", KERNEL=="cdrom", RUN+="/bin/sh -c 'echo 0 > /proc/sys/dev/cdrom/autoclose'"

LABEL="end"
